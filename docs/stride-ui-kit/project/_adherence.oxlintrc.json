{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/general/AgentBadge/**",
              "components/general/AnimatedNumber/**",
              "components/general/ChatPanel/**",
              "components/general/CoachBubble/**",
              "components/general/DailyGuidanceCard/**",
              "components/general/InputBar/**",
              "components/general/MacroCard/**",
              "components/general/MealLogCard/**",
              "components/general/MealLogCardEmpty/**",
              "components/general/MilestoneCard/**",
              "components/general/NarrativeCard/**",
              "components/general/RecipeCard/**",
              "components/general/RecipeCreateModal/**",
              "components/general/RecipeDetailModal/**",
              "components/general/StatChip/**",
              "components/general/StreakCard/**",
              "components/general/StrideMark/**",
              "components/general/WaterTracker/**",
              "components/general/WorkoutCard/**",
              "components/general/WorkoutCardEmpty/**",
              "components/general/WorkoutSessionCard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope))/i]",
        "message": "Font not provided by the design system. Available: Manrope."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|size|key|ref|className|style|children)$/]",
        "message": "<AgentBadge> doesn't accept that prop. Declared props: type, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentBadge'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:diet|workout|sleep|hydration|habits|mental|overall)$/]",
        "message": "<AgentBadge> type must be one of 'diet' | 'workout' | 'sleep' | 'hydration' | 'habits' | 'mental' | 'overall'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<AgentBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AnimatedNumber'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|className|suffix|duration|key|ref|className|style|children)$/]",
        "message": "<AnimatedNumber> doesn't accept that prop. Declared props: value, className, suffix, duration."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoachBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:messages|agentType|defaultStyle|key|ref|className|style|children)$/]",
        "message": "<CoachBubble> doesn't accept that prop. Declared props: messages, agentType, defaultStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoachBubble'] > JSXAttribute[name.name='agentType'] > Literal[value!=/^(?:diet|workout|sleep|hydration|habits|mental|overall)$/]",
        "message": "<CoachBubble> agentType must be one of 'diet' | 'workout' | 'sleep' | 'hydration' | 'habits' | 'mental' | 'overall'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoachBubble'] > JSXAttribute[name.name='defaultStyle'] > Literal[value!=/^(?:gentle|motivating|analytical)$/]",
        "message": "<CoachBubble> defaultStyle must be one of 'gentle' | 'motivating' | 'analytical'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DailyGuidanceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:doToday|recoverFrom|ignoreToday|key|ref|className|style|children)$/]",
        "message": "<DailyGuidanceCard> doesn't accept that prop. Declared props: doToday, recoverFrom, ignoreToday."
      },
      {
        "selector": "JSXOpeningElement[name.name='InputBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|activeMode|onModeChange|key|ref|className|style|children)$/]",
        "message": "<InputBar> doesn't accept that prop. Declared props: placeholder, activeMode, onModeChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='InputBar'] > JSXAttribute[name.name='activeMode'] > Literal[value!=/^(?:type|voice|photo|barcode|ocr)$/]",
        "message": "<InputBar> activeMode must be one of 'type' | 'voice' | 'photo' | 'barcode' | 'ocr'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MacroCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:kcal|protein|carbs|fat|key|ref|className|style|children)$/]",
        "message": "<MacroCard> doesn't accept that prop. Declared props: kcal, protein, carbs, fat."
      },
      {
        "selector": "JSXOpeningElement[name.name='MealLogCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:meal|time|macros|confirmed|key|ref|className|style|children)$/]",
        "message": "<MealLogCard> doesn't accept that prop. Declared props: meal, time, macros, confirmed."
      },
      {
        "selector": "JSXOpeningElement[name.name='MilestoneCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:milestones|key|ref|className|style|children)$/]",
        "message": "<MilestoneCard> doesn't accept that prop. Declared props: milestones."
      },
      {
        "selector": "JSXOpeningElement[name.name='NarrativeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|narrative|date|key|ref|className|style|children)$/]",
        "message": "<NarrativeCard> doesn't accept that prop. Declared props: type, narrative, date."
      },
      {
        "selector": "JSXOpeningElement[name.name='NarrativeCard'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:daily|weekly)$/]",
        "message": "<NarrativeCard> type must be one of 'daily' | 'weekly'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RecipeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:recipe|onOpen|key|ref|className|style|children)$/]",
        "message": "<RecipeCard> doesn't accept that prop. Declared props: recipe, onOpen."
      },
      {
        "selector": "JSXOpeningElement[name.name='RecipeCreateModal'] > JSXAttribute > JSXIdentifier[name!=/^(?:onClose|onCreate|key|ref|className|style|children)$/]",
        "message": "<RecipeCreateModal> doesn't accept that prop. Declared props: onClose, onCreate."
      },
      {
        "selector": "JSXOpeningElement[name.name='RecipeDetailModal'] > JSXAttribute > JSXIdentifier[name!=/^(?:recipe|onClose|onLog|key|ref|className|style|children)$/]",
        "message": "<RecipeDetailModal> doesn't accept that prop. Declared props: recipe, onClose, onLog."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|color|key|ref|className|style|children)$/]",
        "message": "<StatChip> doesn't accept that prop. Declared props: label, value, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatChip'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:mint|sky|peach|bubblegum)$/]",
        "message": "<StatChip> color must be one of 'mint' | 'sky' | 'peach' | 'bubblegum'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StreakCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:days|label|quote|key|ref|className|style|children)$/]",
        "message": "<StreakCard> doesn't accept that prop. Declared props: days, label, quote."
      },
      {
        "selector": "JSXOpeningElement[name.name='StrideMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|key|ref|className|style|children)$/]",
        "message": "<StrideMark> doesn't accept that prop. Declared props: className."
      },
      {
        "selector": "JSXOpeningElement[name.name='WaterTracker'] > JSXAttribute > JSXIdentifier[name!=/^(?:initial|target|unit|key|ref|className|style|children)$/]",
        "message": "<WaterTracker> doesn't accept that prop. Declared props: initial, target, unit."
      },
      {
        "selector": "JSXOpeningElement[name.name='WaterTracker'] > JSXAttribute[name.name='unit'] > Literal[value!=/^(?:ml|oz)$/]",
        "message": "<WaterTracker> unit must be one of 'ml' | 'oz'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkoutCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:exercise|sets|reps|weight|burnKcal|date|key|ref|className|style|children)$/]",
        "message": "<WorkoutCard> doesn't accept that prop. Declared props: exercise, sets, reps, weight, burnKcal, date."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkoutSessionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:session|index|key|ref|className|style|children)$/]",
        "message": "<WorkoutSessionCard> doesn't accept that prop. Declared props: session, index."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
