# Convex Deployment (generated by `npx convex dev`)
CONVEX_DEPLOYMENT=local:yourname-projectname

# Convex URLs (set automatically by Convex CLI)
CONVEX_URL=http://127.0.0.1:3210
CONVEX_SITE_URL=http://127.0.0.1:3211

# Frontend URL (used to build the frontend)
VITE_CONVEX_URL=http://127.0.0.1:3210

# OpenRouter API Key (for AI features: chat, meal estimation, insights)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
