# Convex backend URL
# For local development: http://127.0.0.1:3210
# For production: your Convex deployment URL (from Convex dashboard)
VITE_CONVEX_URL=http://127.0.0.1:3210

# Clerk publishable key (frontend)
# Get this from your Clerk dashboard: https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
