# AI Fitness Tracker - Environment Configuration
#
# Copy this file to .env.local in both backend/ and frontend/ directories
# and fill in your values.

# -- Backend (backend/.env.local) --
# OpenRouter API Key for AI features (chat, meal estimation, insights)
# Get it from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# -- Frontend (frontend/.env.local) --
# Convex backend URL
VITE_CONVEX_URL=http://127.0.0.1:3210
